rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    // These are evaluated per-request; Firestore caches the get() result
    // within a single rule evaluation so multiple calls are not extra reads.

    function userRef() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return request.auth != null && exists(userRef());
    }

    function userDoc() {
      return get(userRef()).data;
    }

    function isAdmin() {
      return request.auth != null
        && userDocExists()
        && userDoc().role == 'admin'
        && userDoc().active != false;
    }

    function isActiveStaff() {
      return request.auth != null
        && userDocExists()
        && userDoc().role == 'staff'
        && userDoc().active != false;
    }

    // Any non-deactivated authenticated user (admin OR staff)
    function isActiveUser() {
      return isAdmin() || isActiveStaff();
    }

    // Student self-service session — a custom-token Firebase Auth identity
    // (minted by the studentLogin Cloud Function) carrying a `student` claim
    // plus either `regNumber` (normal case) or `studentDocId` (pending-admission
    // fallback, before a reg number has been allotted). See functions/src/index.ts.
    function isStudentClaim() {
      return request.auth != null && request.auth.token.student == true;
    }

    function isOwnStudentDoc(studentId, data) {
      return isStudentClaim() && (
        (request.auth.token.regNumber is string && data.regNumber == request.auth.token.regNumber) ||
        (request.auth.token.studentDocId is string && studentId == request.auth.token.studentDocId)
      );
    }

    // For collections keyed by studentId (not regNumber directly) — cross-check
    // the referenced student doc's regNumber against the caller's claim.
    function isOwnStudentRef(studentId) {
      return isStudentClaim()
        && exists(/databases/$(database)/documents/students/$(studentId))
        && get(/databases/$(database)/documents/students/$(studentId)).data.regNumber == request.auth.token.regNumber;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users read their own doc; admins read all (for staff list)
      allow read: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
      // First-time admin self-bootstrap (no doc yet → create own doc)
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !exists(userRef());
      // Only active admins can write user docs (create/update staff accounts)
      allow write: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read:  if isActiveUser();
      allow write: if isAdmin();
    }

    // ── Students ──────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read:   if isActiveUser() || isOwnStudentDoc(studentId, resource.data);
      // Both admin and active staff can enroll (create/update) students
      allow create: if isActiveUser()
        && request.resource.data.keys().hasAll([
             'studentNameSSLC', 'course', 'academicYear',
             'meritNumber', 'regNumber'
           ]);
      allow update: if isActiveUser();
      // Only admins can permanently delete a student record
      allow delete: if isAdmin();
    }

    // ── Fee Structure ─────────────────────────────────────────────────────
    match /feeStructure/{structureId} {
      allow read: if isActiveUser() || isStudentClaim();
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll([
             'academicYear', 'course', 'smp', 'svk'
           ]);
      allow update, delete: if isAdmin();
    }

    // ── Fee Records ───────────────────────────────────────────────────────
    match /feeRecords/{recordId} {
      allow read: if isActiveUser()
        || (isStudentClaim() && resource.data.regNumber == request.auth.token.regNumber);
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll([
             'studentId', 'academicYear', 'smp', 'svk', 'date'
           ]);
      allow update, delete: if isAdmin();
    }

    // ── Fine Schedules ────────────────────────────────────────────────────
    match /fineSchedules/{yearId} {
      allow read:  if isActiveUser();
      allow write: if isAdmin();
    }

    // ── Student Documents ─────────────────────────────────────────────────
    match /studentDocuments/{studentId} {
      allow read:  if isActiveUser();
      // Both admin and staff can track document status
      allow write: if isActiveUser();
    }

    // ── Exam Fee Records ──────────────────────────────────────────────────
    match /examFeeRecords/{recordId} {
      allow read:  if isActiveUser();
      allow write: if isAdmin();
    }

    // ── Counters ──────────────────────────────────────────────────────────
    // Merit/reg number counters — written during enrollment transactions.
    // Both admin and staff can enroll, so both need write access here.
    match /counters/{counterId} {
      allow read:  if isActiveUser();
      allow write: if isActiveUser();
    }

    // ── Receipt Number Counters ───────────────────────────────────────────
    // One document per academic year tracks the highest SMP/SVK/Additional
    // receipt number issued. Written inside Firestore transactions to guarantee
    // uniqueness under concurrent fee collection by multiple staff users.
    match /receiptCounters/{academicYear} {
      allow read:  if isActiveUser();
      allow write: if isActiveUser();
    }

    // ── Inquiries ─────────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.keys().hasAll(['studentName', 'academicYear', 'status'])
        && request.resource.data.keys().hasAny(['mobile', 'parentMobile']);
      allow update: if isActiveUser();
      // Only admins can delete inquiries
      allow delete: if isAdmin();
    }

    // ── Fee Overrides ─────────────────────────────────────────────────────
    match /feeOverrides/{overrideId} {
      // resource is null when the override doc doesn't exist (the common case —
      // most students have no override); only enforce ownership when data exists.
      allow read: if isActiveUser()
        || (isStudentClaim() && (resource == null || isOwnStudentRef(resource.data.studentId)));
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll([
             'studentId', 'academicYear', 'smp', 'svk'
           ]);
      allow delete: if isAdmin();
    }

    // ── SNQ Fee Refunds ───────────────────────────────────────────────────
    match /refunds/{refundId} {
      allow read: if isActiveUser()
        || (isStudentClaim() && resource.data.regNumber == request.auth.token.regNumber);
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll([
             'studentId', 'academicYear', 'refundAmount', 'paymentType', 'paymentDate'
           ]);
      allow delete: if isAdmin();
    }

    // ── Public meta (pre-aggregated stats readable by anyone) ────────────
    // Only the publicStats document lives here; written by authenticated users,
    // read publicly so the login screen can display enrollment statistics.
    match /meta/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Admin Config (API keys, SMS config, etc.) ─────────────────────────
    match /adminConfig/{docId} {
      allow read, write: if isAdmin();
    }

    // ── App Config (CCC counter, etc.) ────────────────────────────────────
    // Active users need read+write so certificate number transactions work.
    match /config/{docId} {
      allow read:  if isActiveUser();
      allow write: if isActiveUser();
    }

    // ── Merit List Snapshots ──────────────────────────────────────────────
    match /meritListSnapshots/{snapshotId} {
      allow read:  if isActiveUser();
      allow write: if isAdmin();
    }

    // ── SMS Logs ──────────────────────────────────────────────────────────
    // Writes come from Cloud Functions (Admin SDK bypasses rules);
    // rule below prevents direct browser writes from non-admins.
    match /smsLogs/{logId} {
      allow read:  if isActiveUser();
      allow write: if isAdmin();
    }

    // ── Fee Remittances ───────────────────────────────────────────────────────
    match /feeRemittances/{docId} {
      allow read:  if isActiveUser();
      allow write: if isAdmin();
    }

    // ── Exam Results (parsed from Result Ledger PDFs) ─────────────────────
    // Both admin and staff can view; students can view their own (read-only,
    // matched via regNumber — part of the student portal's academic profile).
    match /examResults/{resultId} {
      allow read: if isActiveUser()
        || (isStudentClaim() && resource.data.regNumber == request.auth.token.regNumber);
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['regNumber', 'studentName', 'examSession']);
      allow delete: if isAdmin();
    }

    // ── Login Attempts (studentLogin throttling) ──────────────────────────
    // Written only by the studentLogin Cloud Function via the Admin SDK,
    // which bypasses rules entirely — this rule blocks any direct client access.
    match /loginAttempts/{key} {
      allow read, write: if false;
    }

    // ── Student Portal Login Activity ("active users") ─────────────────────
    // Docs are created only by the studentLogin Cloud Function via the Admin SDK
    // (bypasses rules). The signed-in student may flip their own online/offline
    // status on logout — nothing else about the doc — everything else is admin/staff read-only.
    match /studentLoginActivity/{uid} {
      allow read:   if isActiveUser();
      allow update: if isStudentClaim() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['online', 'lastLogoutAt']);
      allow create, delete: if false;
    }

    // ── Notices (admin → student announcements) ───────────────────────────
    match /notices/{noticeId} {
      allow read:  if isActiveUser() || isStudentClaim();
      allow write: if isAdmin();
    }

    // ── Circulars (admin → ALL students; department is a label, not access control) ─
    match /circulars/{circularId} {
      allow read:  if isActiveUser() || isStudentClaim();
      allow write: if isAdmin();
    }

    // ── Student Circular Seen-State (unread badge) ────────────────────────
    match /studentCircularState/{regNumber} {
      allow read, write: if isActiveUser()
        || (isStudentClaim() && regNumber == request.auth.token.regNumber);
    }

    // ── Student Messages (student → admin queries) ────────────────────────
    match /studentMessages/{msgId} {
      allow read:   if isActiveUser()
        || (isStudentClaim() && resource.data.regNumber == request.auth.token.regNumber);
      allow create: if isStudentClaim()
        && request.resource.data.regNumber == request.auth.token.regNumber
        && request.resource.data.keys().hasAll(['regNumber', 'studentName', 'category', 'message', 'status']);
      allow update: if isActiveUser();
      allow delete: if isAdmin();
    }

    // ── Student Notice Clear-State (student self-service dismiss) ─────────
    match /studentNoticeState/{regNumber} {
      allow read, write: if isActiveUser()
        || (isStudentClaim() && regNumber == request.auth.token.regNumber);
    }


    // ── Student Notifications (admin/staff → student, record-change alerts) ─
    match /studentNotifications/{id} {
      allow read:   if isActiveUser()
        || (isStudentClaim() && resource.data.regNumber == request.auth.token.regNumber);
      allow create: if isActiveUser()
        && request.resource.data.keys().hasAll(['studentId', 'regNumber', 'type', 'title', 'message', 'createdAt', 'seen']);
      allow update: if isActiveUser()
        || (isStudentClaim() && resource.data.regNumber == request.auth.token.regNumber);
      allow delete: if isAdmin();
    }
  }
}
