rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Users can read their own role doc (needed on login);
      // admins can read all user docs (needed for staff list query)
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true)
      );
      // A user with no doc yet (original admin, first login) can create their own doc
      allow create: if request.auth != null && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
      // Admin users can write any user doc (create/update staff accounts)
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }
    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
             'studentNameSSLC', 'course', 'academicYear',
             'meritNumber', 'regNumber'
           ]);
      allow update, delete: if request.auth != null;
    }
    match /feeStructure/{structureId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
             'academicYear', 'course', 'smp', 'svk'
           ]);
      allow update, delete: if request.auth != null;
    }
    match /feeRecords/{recordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
             'studentId', 'academicYear', 'smp', 'svk', 'date'
           ]);
      allow update, delete: if request.auth != null;
    }
    match /fineSchedules/{yearId} {
      allow read, write: if request.auth != null;
    }
    match /studentDocuments/{studentId} {
      allow read, write: if request.auth != null;
    }
    match /examFeeRecords/{recordId} {
      allow read, write: if request.auth != null;
    }
  }
}
