rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Storage Rules cannot read Firestore documents, so admin status is checked
    // via a custom Auth claim kept in sync by the syncAdminClaim Cloud Function
    // (functions/src/index.ts), which mirrors users/{uid}.role/active on write.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Fee Remittance soft copies (K2 challan / payment proof) ────────────
    // Payee-level: remittanceChallans/{id}/{file}; per-head (GOV): remittanceChallans/{id}/{headKey}/{file}
    match /remittanceChallans/{remittanceId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/jpeg|image/png');
    }
  }
}
